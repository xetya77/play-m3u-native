<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_edit_dialog"
    android:padding="28dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/delete_playlist_title"
        android:textColor="#E4EEF0"
        android:textSize="20sp"
        android:fontFamily="@font/inter_bold"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_delete_playlist_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8AACB0"
        android:textSize="14sp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginBottom="28dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btn_delete_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/delete_playlist_cancel"
            android:textColor="#8AACB0"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="@drawable/bg_btn_dialog_cancel"
            android:focusable="true"
            android:clickable="true"/>

        <TextView
            android:id="@+id/btn_delete_confirm"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/delete_playlist_confirm"
            android:textColor="#16232A"
            android:textSize="14sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="@drawable/selector_delete_btn"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
