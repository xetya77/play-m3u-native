<?xml version="1.0" encoding="utf-8"?>
<!-- Card playlist: bg #075056, radius 16dp, padding 20dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_settings_panel"
    android:layout_marginBottom="12dp">

    <!-- Row atas: nama + badge AKTIF -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_pl_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E4EEF0"
            android:textSize="17sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Badge AKTIF — hanya tampil untuk playlist aktif -->
        <TextView
            android:id="@+id/tv_pl_active_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTIF"
            android:textColor="#FF5B04"
            android:textSize="10sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_url_stepper_active"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Info: channel count & sumber -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_pl_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80E4EEF0"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"/>

        <TextView
            android:id="@+id/tv_pl_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#60E4EEF0"
            android:textSize="11sp"
            android:fontFamily="@font/inter_regular"/>
    </LinearLayout>

    <!-- Divider tipis -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#20E4EEF0"/>

    <!-- Row bawah: tombol Edit Nama | Edit URL | Hapus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <!-- Edit Nama -->
        <TextView
            android:id="@+id/btn_pl_edit_name"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Edit Nama"
            android:textColor="#E4EEF0"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_settings_menu_normal"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#20E4EEF0"/>

        <!-- Edit URL -->
        <TextView
            android:id="@+id/btn_pl_edit_url"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Edit URL"
            android:textColor="#E4EEF0"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_settings_menu_normal"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#20E4EEF0"/>

        <!-- Hapus -->
        <TextView
            android:id="@+id/btn_pl_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Hapus"
            android:textColor="#FF5B04"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_settings_menu_normal"/>
    </LinearLayout>
</LinearLayout>
