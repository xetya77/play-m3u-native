<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_edit_dialog">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_picker_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:textColor="#E4EEF0"
        android:textSize="18sp"
        android:fontFamily="@font/inter_bold"
        android:textStyle="bold"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"/>

    <!-- List items dalam container fixed height agar tombol selalu terlihat -->
    <ListView
        android:id="@+id/lv_picker_items"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:divider="#0DFFFFFF"
        android:dividerHeight="1dp"
        android:scrollbars="vertical"
        android:overScrollMode="never"
        android:fastScrollEnabled="false"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"/>

    <!-- Buttons — selalu di bawah, tidak terdorong keluar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/btn_picker_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/appsettings_cancel"
            android:textColor="#8AACB0"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="@drawable/bg_btn_dialog_cancel"
            android:focusable="true"
            android:clickable="true"/>

        <TextView
            android:id="@+id/btn_picker_save"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/appsettings_save"
            android:textColor="#16232A"
            android:textSize="14sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="@drawable/selector_exit_btn"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
