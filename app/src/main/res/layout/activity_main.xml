<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ===== PAGE WELCOME (new design) ===== -->
    <LinearLayout
        android:id="@+id/page_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/welcome_bg"
        android:visibility="gone">

        <!-- Spacer atas 12% layar -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="12"/>

        <!-- Icon logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_app_logo"
            android:scaleType="fitCenter"/>

        <!-- Gap icon → Welcome to: ~5% -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"/>

        <!-- Welcome to -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Welcome to"
            android:textColor="#60163A2A"
            android:textSize="17sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"/>

        <!-- PlayM3U -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="PlayM3U"
            android:textColor="@color/welcome_dark"
            android:textSize="34sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <!-- Gap PlayM3U → tagline: ~8% -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="8"/>

        <!-- Tagline — dua baris: Stream your M3U playlists / in one place. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Stream your M3U playlists
in one place."
            android:textColor="@color/welcome_dark"
            android:textSize="17sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:fontFamily="@font/inter_medium"
            android:alpha="0.6"/>

        <!-- Flexible space sebelum button -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="20"/>

        <!-- Button Get Started -->
        <TextView
            android:id="@+id/btn_welcome_add"
            android:layout_width="260dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Get Started"
            android:textColor="@color/welcome_bg"
            android:textSize="22sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_welcome_btn"
            android:focusable="true"
            android:clickable="true"/>

        <!-- Gap button → Press OK: ~3% -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"/>

        <!-- Press OK to start -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Press OK to start"
            android:textColor="@color/welcome_dark"
            android:textSize="13sp"
            android:textStyle="italic"
            android:fontFamily="@font/inter_medium"
            android:alpha="0.5"/>

        <!-- Bottom spacer: ~8% -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="8"/>

    </LinearLayout>

    <!-- ===== PAGE SOURCE (new design) ===== -->
    <LinearLayout
        android:id="@+id/page_source"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/welcome_bg"
        android:visibility="gone">

        <!-- Stepper: IDENTIK dengan URL page — 76dp×6dp, gap 8dp, marginTop 47dp -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="6dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="47dp"
            android:orientation="horizontal">
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_stepper_active"
                android:layout_marginEnd="8dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_stepper_inactive"
                android:layout_marginEnd="8dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_stepper_inactive"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="10"/>

        <!-- Heading: 17sp Inter Bold #16232A -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Import M3U from where?"
            android:textColor="#16232A"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <!-- Option 1: Link/URL — 288x108dp -->
        <LinearLayout
            android:id="@+id/source_url_item"
            android:layout_width="288dp"
            android:layout_height="108dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/selector_source_option">

            <ImageView
                android:id="@+id/checkbox_url"
                android:layout_width="19dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_triangle_play"
                android:visibility="gone"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Link/URL"
                android:textColor="#E4EEF0"
                android:textSize="24sp"
                android:fontFamily="@font/inter_medium"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="24dp"/>

        <!-- Option 2: Local File — 288x108dp -->
        <LinearLayout
            android:id="@+id/source_file_item"
            android:layout_width="288dp"
            android:layout_height="108dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/selector_source_option">

            <ImageView
                android:id="@+id/checkbox_file"
                android:layout_width="19dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_triangle_play"
                android:visibility="gone"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Local File"
                android:textColor="#E4EEF0"
                android:textSize="24sp"
                android:fontFamily="@font/inter_medium"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="20"/>

        <!-- Next step: 181x68dp, warna #075056 -->
        <TextView
            android:id="@+id/btn_source_next"
            android:layout_width="181dp"
            android:layout_height="68dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Next step"
            android:textColor="#E4EEF0"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_next_step_btn"
            android:focusable="true"
            android:clickable="true"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <!-- Helper text: #16232A 70% opacity, center, italic 11sp -->
        <TextView
            android:id="@+id/tv_source_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Choose one to continue"
            android:textColor="#16232A"
            android:textSize="11sp"
            android:textStyle="italic"
            android:fontFamily="@font/inter_medium"
            android:alpha="0.7"/>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="8"/>

    </LinearLayout>

        <!-- ===== PAGE URL (new PDF design) ===== -->
    <LinearLayout
        android:id="@+id/page_url"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#075056"
        android:visibility="gone">

        <!-- Stepper: 3 bars, bar1+bar2 active #FF5B04, bar3 inactive -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="6dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="47dp"
            android:orientation="horizontal">
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_active"
                android:layout_marginEnd="8dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_active"
                android:layout_marginEnd="8dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_inactive"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="8"/>

        <!-- Heading: "What's your M3U URL?" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="What's your M3U URL?"
            android:textColor="#E4EEF0"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Input URL: 290x82dp, rounded pill -->
        <EditText
            android:id="@+id/et_url"
            android:layout_width="290dp"
            android:layout_height="82dp"
            android:layout_gravity="center_horizontal"
            android:hint="Enter playlist URL..."
            android:textColorHint="#80E4EEF0"
            android:textColor="#E4EEF0"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="@drawable/selector_url_input"
            android:inputType="textUri"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:layout_marginBottom="32dp"/>

        <!-- "Enable auto refresh?" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Enable auto refresh?"
            android:textColor="#E4EEF0"
            android:textSize="18sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Yes/No Swipeable Toggle -->
        <FrameLayout
            android:id="@+id/toggle_container"
            android:layout_width="290dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_yesno_container"
            android:layout_marginBottom="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Thumb geser (pill oranye) -->
            <View
                android:id="@+id/toggle_thumb"
                android:layout_width="145dp"
                android:layout_height="72dp"
                android:layout_gravity="start"
                android:background="@drawable/bg_yesno_selected"/>

            <!-- Label Yes -->
            <TextView
                android:id="@+id/radio_yes"
                android:layout_width="145dp"
                android:layout_height="72dp"
                android:layout_gravity="start"
                android:gravity="center"
                android:text="Yes"
                android:textColor="#E4EEF0"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:clickable="false"
                android:focusable="false"/>

            <!-- Label No -->
            <TextView
                android:id="@+id/radio_no"
                android:layout_width="145dp"
                android:layout_height="72dp"
                android:layout_gravity="end"
                android:gravity="center"
                android:text="No"
                android:textColor="#E4EEF0"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:clickable="false"
                android:focusable="false"/>
        </FrameLayout>

        <!-- Helper italic: "The playlist will update..." -->
        <TextView
            android:id="@+id/tv_ch_count_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="The playlist will update each time you
open the app."
            android:textColor="#E4EEF0"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:textStyle="italic"
            android:alpha="0.7"
            android:layout_marginBottom="8dp"/>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="20"/>

        <!-- Add playlist button: 200x70dp, #E4EEF0 normal, #FF5B04 pressed -->
        <TextView
            android:id="@+id/btn_url_next"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Add playlist"
            android:textColor="#16232A"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            android:textStyle="normal"
            android:background="@drawable/bg_add_playlist_btn"
            android:focusable="true"
            android:clickable="true"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <!-- Bottom helper italic -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Paste the direct link to your M3U playlist
and Press Add playlist"
            android:textColor="#E4EEF0"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:textStyle="italic"
            android:alpha="0.7"/>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="6"/>

    </LinearLayout>

    <!-- ===== PAGE NAME (hidden, tetap ada untuk kompatibilitas Java) ===== -->
    <LinearLayout
        android:id="@+id/page_name"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0D1B22"
        android:visibility="gone">

        <!-- Stepper: 3 bar semua orange (step 3/3) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="47dp"
            android:gravity="center_vertical">
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_active"/>
            <Space android:layout_width="5dp" android:layout_height="0dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_active"/>
            <Space android:layout_width="5dp" android:layout_height="0dp"/>
            <View
                android:layout_width="76dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_url_stepper_active"/>
        </LinearLayout>

        <!-- Spacer atas flexible -->
        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2"/>

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="What should we call
this playlist?"
            android:textColor="#E4EEF0"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="28dp"/>

        <!-- Input nama: 290x82dp pill, teal gelap normal, terang saat fokus -->
        <EditText
            android:id="@+id/et_name"
            android:layout_width="290dp"
            android:layout_height="82dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/selector_name_input"
            android:hint="Enter playlist name..."
            android:textColorHint="#80E4EEF0"
            android:textColor="#E4EEF0"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLines="1"/>

        <!-- Spacer tengah flexible -->
        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="5"/>

        <!-- Button Done: 200x70dp, default #E4EEF0, ada teks → #FF5B04 -->
        <TextView
            android:id="@+id/btn_name_save"
            android:layout_width="200dp"
            android:layout_height="70dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Done"
            android:textColor="#16232A"
            android:textSize="17sp"
            android:fontFamily="@font/inter_medium"
            android:background="@drawable/bg_done_btn"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="10dp"/>

        <!-- Footer italic -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Give it a name to keep things organized."
            android:textColor="#80E4EEF0"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular"
            android:textStyle="italic"
            android:layout_marginBottom="32dp"/>

        <!-- Dummy hidden views agar Java tidak NPE -->
        <TextView android:id="@+id/btn_url_back"    android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <TextView android:id="@+id/btn_url_clear"   android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <TextView android:id="@+id/btn_name_back"   android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <TextView android:id="@+id/btn_name_clear"  android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_ch_count_name" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <View     android:id="@+id/radio_box_yes"   android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <View     android:id="@+id/radio_box_no"    android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
    </LinearLayout>

        <!-- Dummy views EPG — dihapus dari UI, hanya agar Java tidak NPE -->
        <View android:id="@+id/page_epg_source" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/page_epg" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <EditText android:id="@+id/et_epg_url" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/btn_epg_load" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/card_epg_loading" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/card_epg_success" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/card_epg_error" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/epg_progress_fill" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_epg_loading_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_epg_prog_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_epg_success_msg" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/epg_source_url_item" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/epg_source_file_item" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <!-- ===== PAGE PLAYLISTS ===== -->
    <LinearLayout
        android:id="@+id/page_playlists"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#16232A"
        android:visibility="gone">

        <!-- ── Top bar: judul + tombol X ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="44dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Playlists"
                android:textColor="#E4EEF0"
                android:textSize="28sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"/>

            <!-- Tombol ← kembali ke settings — tidak pakai circle agar tidak terpotong -->
            <TextView
                android:id="@+id/btn_playlists_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="&#8592;"
                android:textColor="#E4EEF0"
                android:textSize="30sp"
                android:fontFamily="@font/inter_bold"
                android:paddingStart="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <!-- ── Daftar playlist (scrollable) ── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false">
            <LinearLayout
                android:id="@+id/playlist_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"/>
        </ScrollView>

        <!-- ── Panel teal bawah (sama dengan settings) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_panel"
            android:paddingTop="12dp"
            android:paddingBottom="28dp">

            <!-- Update All Playlists -->
            <FrameLayout
                android:id="@+id/btn_update_playlist"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_settings_menu_normal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ic_update_play"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:src="@drawable/ic_triangle_play"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_update_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Update Semua"
                    android:textColor="#E4EEF0"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_medium"/>
            </FrameLayout>

            <!-- Switch Active Playlist -->
            <FrameLayout
                android:id="@+id/btn_switch_playlist"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_settings_menu_normal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ic_switch_play"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:src="@drawable/ic_triangle_play"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_switch_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Ganti Aktif"
                    android:textColor="#E4EEF0"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_medium"/>
            </FrameLayout>

            <!-- Tambah Playlist -->
            <FrameLayout
                android:id="@+id/btn_add_new_playlist"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_settings_menu_normal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ic_add_play"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:src="@drawable/ic_triangle_play"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_add_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Tambah Playlist"
                    android:textColor="#E4EEF0"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_medium"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Hidden compat views -->
        <TextView android:id="@+id/tv_update_success"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ===== LOADING OVERLAY (PDF card design) ===== -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A1628"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Card: Loading state -->
        <LinearLayout
            android:id="@+id/card_loading"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:visibility="visible">

            <!-- "+ Adding Playlist..." dengan dots animasi -->
            <TextView
                android:id="@+id/tv_loading_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Adding Playlist..."
                android:textColor="#607D8B"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="4dp"/>

            <!-- "50 Ch • Available" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_ch_count_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Ch"
                    android:textColor="#16232A"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#FF5B04"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available"
                    android:textColor="#16232A"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Progress labels: 0% 50% 100% -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0%"
                    android:textColor="#90607D8B"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="start"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="50%"
                    android:textColor="#90607D8B"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="100%"
                    android:textColor="#90607D8B"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Progress bar track + fill -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <!-- Track (dark background) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_progress_track"/>

                <!-- Fill (orange) -->
                <View
                    android:id="@+id/progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_progress_fill"/>

                <!-- Divider tengah -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="#40E4EEF0"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Card: Success state -->
        <LinearLayout
            android:id="@+id/card_success"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlist added"
                android:textColor="#16232A"
                android:textSize="20sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Checkmark icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp">
                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_status_success"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✓"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_success_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="124 channels
imported."
                android:textColor="#16232A"
                android:textSize="16sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <!-- Card: Error state -->
        <LinearLayout
            android:id="@+id/card_error"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unable to load"
                android:textColor="#16232A"
                android:textSize="20sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- X icon circle -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp">
                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_status_error"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check the URL
and try again"
                android:textColor="#16232A"
                android:textSize="16sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>


            <!-- Switch Active Playlist -->
            <FrameLayout
                android:id="@+id/btn_switch_playlist"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_settings_menu_normal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ic_switch_play"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:src="@drawable/ic_triangle_play"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_switch_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Ganti Aktif"
                    android:textColor="#E4EEF0"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_medium"/>
            </FrameLayout>

            <!-- Tambah Playlist -->
            <FrameLayout
                android:id="@+id/btn_add_new_playlist"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_settings_menu_normal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ic_add_play"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:src="@drawable/ic_triangle_play"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_add_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Tambah Playlist"
                    android:textColor="#E4EEF0"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_medium"/>
            </FrameLayout>

        <!-- Hidden compat views -->
        <TextView android:id="@+id/tv_update_success"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
        <!-- Hidden stubs for page_settings and settings views -->
        <LinearLayout android:id="@+id/page_settings"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:visibility="gone">
            <TextView android:id="@+id/tv_settings_playlist_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:visibility="gone"/>
            <View android:id="@+id/btn_settings_exit"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <View android:id="@+id/btn_start_watch"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <View android:id="@+id/btn_go_playlists"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <View android:id="@+id/btn_add_playlist_settings"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tv_start_label"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageView android:id="@+id/ic_start_play"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tv_playlist_label"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageView android:id="@+id/ic_playlist_play"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
        </LinearLayout>
        <!-- Hidden stubs for loading text views -->
        <TextView android:id="@+id/tv_loading_text"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
        <TextView android:id="@+id/tv_loading_sub"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- ===== PLAYLIST SWITCHER MODAL (bottom-sheet) ===== -->
    <LinearLayout
        android:id="@+id/switcher_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:background="#CC0A1628"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/switcher_modal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_panel"
            android:paddingTop="16dp"
            android:paddingBottom="36dp">

            <!-- Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="#40E4EEF0"/>

            <!-- Judul -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih Playlist Aktif"
                android:textColor="#E4EEF0"
                android:textSize="18sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- List playlist -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="340dp">
                <LinearLayout
                    android:id="@+id/switcher_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
            </ScrollView>

            <!-- Tutup pill -->
            <TextView
                android:id="@+id/btn_switcher_close"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Tutup"
                android:textColor="#16232A"
                android:textSize="15sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:background="@drawable/bg_add_playlist_btn"
                android:focusable="true"
                android:clickable="true"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>