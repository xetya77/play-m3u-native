<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout LANDSCAPE untuk MainActivity.
    Semua android:id IDENTIK dengan layout portrait agar Java tidak NPE.
    Strategi tiap halaman:
      - Welcome, Source, URL, Name  → dua kolom: kiri branding, kanan konten
      - Settings, Playlists         → dua kolom: kiri nama/judul, kanan aksi
      - Loading overlay, Switcher   → modal center (sama dengan portrait)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ===================================================================
         PAGE WELCOME — landscape: kiri branding, kanan tombol
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/welcome_bg"
        android:visibility="gone">

        <!-- Kolom kiri: logo + judul -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="48dp"
            android:paddingEnd="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_app_logo"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_to"
                android:textColor="#60163A2A"
                android:textSize="15sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PlayM3U"
                android:textColor="@color/welcome_dark"
                android:textSize="30sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/welcome_btn"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_tagline"
                android:textColor="@color/welcome_dark"
                android:textSize="13sp"
                android:gravity="start"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="@font/inter_medium"
                android:alpha="0.6"/>
        </LinearLayout>

        <!-- Kolom kanan: tombol Get Started -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="48dp">

            <TextView
                android:id="@+id/btn_welcome_add"
                android:layout_width="240dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="@string/welcome_get_started"
                android:textColor="@color/welcome_bg"
                android:textSize="20sp"
                android:fontFamily="@font/inter_medium"
                android:background="@drawable/bg_welcome_btn"
                android:focusable="true"
                android:clickable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/welcome_press_ok"
                android:textColor="@color/welcome_dark"
                android:textSize="12sp"
                android:textStyle="italic"
                android:fontFamily="@font/inter_medium"
                android:alpha="0.5"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================================
         PAGE SOURCE — landscape: kiri branding, kanan pilihan sumber
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_source"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/welcome_bg"
        android:visibility="gone">

        <!-- Kolom kiri: stepper + heading -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="48dp"
            android:paddingEnd="32dp">

            <!-- Stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="6dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <View
                    android:layout_width="56dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_stepper_active"
                    android:layout_marginEnd="6dp"/>
                <View
                    android:layout_width="56dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_stepper_inactive"
                    android:layout_marginEnd="6dp"/>
                <View
                    android:layout_width="56dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_stepper_inactive"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/source_heading"
                android:textColor="#16232A"
                android:textSize="26sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.15"/>
        </LinearLayout>

        <!-- Kolom kanan: opsi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="48dp">

            <!-- Link/URL -->
            <LinearLayout
                android:id="@+id/source_url_item"
                android:layout_width="260dp"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_source_option">
                <ImageView
                    android:id="@+id/checkbox_url"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:src="@drawable/ic_triangle_play"
                    android:visibility="gone"
                    android:layout_marginEnd="14dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/source_option_url"
                    android:textColor="#E4EEF0"
                    android:textSize="20sp"
                    android:fontFamily="@font/inter_medium"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- Local File -->
            <LinearLayout
                android:id="@+id/source_file_item"
                android:layout_width="260dp"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_source_option">
                <ImageView
                    android:id="@+id/checkbox_file"
                    android:layout_width="16dp"
                    android:layout_height="19dp"
                    android:src="@drawable/ic_triangle_play"
                    android:visibility="gone"
                    android:layout_marginEnd="14dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/source_option_file"
                    android:textColor="#E4EEF0"
                    android:textSize="20sp"
                    android:fontFamily="@font/inter_medium"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="24dp"/>

            <TextView
                android:id="@+id/btn_source_next"
                android:layout_width="160dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="@string/source_next"
                android:textColor="#E4EEF0"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:background="@drawable/bg_next_step_btn"
                android:focusable="true"
                android:clickable="true"/>

            <TextView
                android:id="@+id/tv_source_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/source_note"
                android:textColor="#16232A"
                android:textSize="11sp"
                android:textStyle="italic"
                android:fontFamily="@font/inter_medium"
                android:alpha="0.7"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================================
         PAGE URL — landscape: kiri heading, kanan input
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_url"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="#075056"
        android:visibility="gone">

        <!-- Kolom kiri: stepper + judul -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="48dp"
            android:paddingEnd="32dp">

            <!-- Stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="6dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_active" android:layout_marginEnd="6dp"/>
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_active" android:layout_marginEnd="6dp"/>
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_inactive"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/url_heading"
                android:textColor="#E4EEF0"
                android:textSize="26sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/url_bottom_note"
                android:textColor="#E4EEF0"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:textStyle="italic"
                android:alpha="0.7"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- Kolom kanan: form input -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="48dp">

            <EditText
                android:id="@+id/et_url"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:hint="@string/url_hint"
                android:textColorHint="#80E4EEF0"
                android:textColor="#E4EEF0"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:background="@drawable/selector_url_input"
                android:inputType="textUri"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/url_auto_refresh"
                android:textColor="#E4EEF0"
                android:textSize="15sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- Toggle Yes/No -->
            <FrameLayout
                android:id="@+id/toggle_container"
                android:layout_width="260dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_yesno_container"
                android:layout_marginBottom="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">
                <View
                    android:id="@+id/toggle_thumb"
                    android:layout_width="130dp"
                    android:layout_height="60dp"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_yesno_selected"/>
                <TextView
                    android:id="@+id/radio_yes"
                    android:layout_width="130dp"
                    android:layout_height="60dp"
                    android:layout_gravity="start"
                    android:gravity="center"
                    android:text="@string/toggle_yes"
                    android:textColor="#E4EEF0"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:clickable="false"
                    android:focusable="false"/>
                <TextView
                    android:id="@+id/radio_no"
                    android:layout_width="130dp"
                    android:layout_height="60dp"
                    android:layout_gravity="end"
                    android:gravity="center"
                    android:text="@string/toggle_no"
                    android:textColor="#E4EEF0"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:clickable="false"
                    android:focusable="false"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_ch_count_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/url_auto_refresh_note"
                android:textColor="#E4EEF0"
                android:textSize="10sp"
                android:fontFamily="@font/inter_medium"
                android:textStyle="italic"
                android:alpha="0.7"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/btn_url_next"
                android:layout_width="180dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="@string/url_add_playlist"
                android:textColor="#16232A"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:background="@drawable/bg_add_playlist_btn"
                android:focusable="true"
                android:clickable="true"/>

            <!-- Dummy hidden views agar Java tidak NPE -->
            <TextView android:id="@+id/btn_url_back"  android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
            <TextView android:id="@+id/btn_url_clear" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================================
         PAGE NAME — landscape: kiri heading, kanan input nama
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_name"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="#0D1B22"
        android:visibility="gone">

        <!-- Kolom kiri -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="48dp"
            android:paddingEnd="32dp">

            <!-- Stepper — semua aktif (step 3/3) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="6dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_active" android:layout_marginEnd="6dp"/>
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_active" android:layout_marginEnd="6dp"/>
                <View android:layout_width="56dp" android:layout_height="6dp"
                    android:background="@drawable/bg_url_stepper_active"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_heading"
                android:textColor="#E4EEF0"
                android:textSize="24sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/name_footer"
                android:textColor="#80E4EEF0"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                android:textStyle="italic"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- Kolom kanan: input + tombol -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="48dp">

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="@drawable/selector_name_input"
                android:hint="@string/name_hint"
                android:textColorHint="#80E4EEF0"
                android:textColor="#E4EEF0"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:maxLines="1"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/btn_name_save"
                android:layout_width="180dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="@string/name_done"
                android:textColor="#16232A"
                android:textSize="16sp"
                android:fontFamily="@font/inter_medium"
                android:background="@drawable/bg_done_btn"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Dummy hidden views -->
            <TextView android:id="@+id/btn_name_back"    android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
            <TextView android:id="@+id/btn_name_clear"   android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
            <TextView android:id="@+id/tv_ch_count_name" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
            <View     android:id="@+id/radio_box_yes"    android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
            <View     android:id="@+id/radio_box_no"     android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================================
         PAGE SETTINGS — landscape: kiri nama playlist, kanan menu
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="#16232A"
        android:visibility="gone">

        <!-- Kolom kiri: nama playlist + titik orange -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="40dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:id="@+id/ll_playlist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_settings_playlist_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="My&#10;Playlist."
                    android:textColor="#E4EEF0"
                    android:textSize="34sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.05"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="-12dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_status_success"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Kolom kanan: tombol X atas + menu panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="32dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Tombol X pojok kanan atas kolom kanan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:layout_marginBottom="16dp">
                <FrameLayout
                    android:id="@+id/btn_settings_exit"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_exit_btn_normal"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="✕"
                        android:textColor="#E4EEF0"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_bold"
                        android:textStyle="bold"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Menu panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_panel"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <!-- START -->
                <FrameLayout
                    android:id="@+id/btn_start_watch"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_menu_normal"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/ic_start_play"
                        android:layout_width="14dp"
                        android:layout_height="17dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_triangle_play"
                        android:scaleType="fitCenter"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tv_start_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/settings_start"
                        android:textColor="#E4EEF0"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_medium"/>
                </FrameLayout>

                <!-- PLAYLIST -->
                <FrameLayout
                    android:id="@+id/btn_go_playlists"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_settings_menu_normal"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/ic_playlist_play"
                        android:layout_width="14dp"
                        android:layout_height="17dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_triangle_play"
                        android:scaleType="fitCenter"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tv_playlist_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/settings_playlist_menu"
                        android:textColor="#E4EEF0"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_medium"/>
                </FrameLayout>

                <!-- EPG -->
                <FrameLayout
                    android:id="@+id/btn_epg"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_settings_menu_normal"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/ic_epg_play"
                        android:layout_width="14dp"
                        android:layout_height="17dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="20dp"
                        android:src="@drawable/ic_triangle_play"
                        android:scaleType="fitCenter"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tv_epg_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/settings_epg"
                        android:textColor="#E4EEF0"
                        android:textSize="18sp"
                        android:fontFamily="@font/inter_medium"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Dummy -->
        <TextView android:id="@+id/btn_add_playlist_settings" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
    </LinearLayout>

    <!-- ===================================================================
         PAGE PLAYLISTS — landscape: kiri header, kanan daftar + aksi
         =================================================================== -->
    <LinearLayout
        android:id="@+id/page_playlists"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="#16232A"
        android:visibility="gone">

        <!-- Kolom kiri: judul + info -->
        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="32dp"
            android:paddingEnd="16dp"
            android:background="#112030">

            <TextView
                android:id="@+id/btn_playlists_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8592;"
                android:textColor="#FF5B04"
                android:textSize="22sp"
                android:fontFamily="@font/inter_bold"
                android:paddingBottom="16dp"
                android:focusable="true"
                android:clickable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_playlist_menu"
                android:textColor="#E4EEF0"
                android:textSize="22sp"
                android:fontFamily="@font/inter_bold"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_playlist_header_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 playlist tersimpan"
                android:textColor="#8AACB0"
                android:textSize="11sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Kolom kanan: daftar + aksi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Daftar -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false">
                <LinearLayout
                    android:id="@+id/playlist_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp"/>
            </ScrollView>

            <!-- Toast sukses -->
            <TextView
                android:id="@+id/tv_update_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlists_updated"
                android:textColor="#16232A"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="#FF5B04"
                android:visibility="gone"/>

            <!-- Bottom action bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_bottom_action_bar"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/btn_update_playlist"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/playlists_refresh_all"
                    android:textColor="#E4EEF0"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_medium"
                    android:background="@drawable/selector_btn_secondary"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btn_switch_playlist"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/playlists_switch_main"
                    android:textColor="#E4EEF0"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_medium"
                    android:background="@drawable/selector_btn_secondary"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btn_add_playlist_main"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/playlists_empty_add"
                    android:textColor="#16232A"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"
                    android:background="@drawable/selector_btn_add_pl"
                    android:focusable="true"
                    android:clickable="true"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================================
         LOADING OVERLAY — identik dengan portrait (modal center)
         =================================================================== -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A1628"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/card_loading"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_loading_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loading_adding"
                android:textColor="#607D8B"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:id="@+id/tv_ch_count_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Ch"
                    android:textColor="#16232A"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#FF5B04"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loading_available"
                    android:textColor="#16232A"
                    android:textSize="28sp"
                    android:fontFamily="@font/inter_bold"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="0%" android:textColor="#90607D8B" android:textSize="11sp"
                    android:fontFamily="@font/inter_regular" android:gravity="start"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="50%" android:textColor="#90607D8B" android:textSize="11sp"
                    android:fontFamily="@font/inter_regular" android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="100%" android:textColor="#90607D8B" android:textSize="11sp"
                    android:fontFamily="@font/inter_regular" android:gravity="end"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="60dp">
                <View android:layout_width="match_parent" android:layout_height="60dp"
                    android:background="@drawable/bg_progress_track"/>
                <View
                    android:id="@+id/progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_progress_fill"/>
                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:layout_gravity="center" android:background="#40E4EEF0"/>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_success"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:gravity="center"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/status_added" android:textColor="#16232A" android:textSize="20sp"
                android:fontFamily="@font/inter_bold" android:textStyle="bold" android:layout_marginBottom="16dp"/>
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:layout_marginBottom="16dp">
                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_status_success"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="✓" android:textColor="#FFFFFF"
                    android:textSize="22sp" android:fontFamily="@font/inter_bold" android:textStyle="bold"/>
            </FrameLayout>
            <TextView android:id="@+id/tv_success_msg" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="124 channels&#10;imported."
                android:textColor="#16232A" android:textSize="16sp" android:fontFamily="@font/inter_medium"
                android:gravity="center" android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_error"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_loading_card"
            android:padding="24dp"
            android:gravity="center"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/status_error_title" android:textColor="#16232A" android:textSize="20sp"
                android:fontFamily="@font/inter_bold" android:textStyle="bold" android:layout_marginBottom="16dp"/>
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:layout_marginBottom="16dp">
                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_status_error"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="✕" android:textColor="#FFFFFF"
                    android:textSize="20sp" android:fontFamily="@font/inter_bold" android:textStyle="bold"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/status_error_hint" android:textColor="#16232A"
                android:textSize="16sp" android:fontFamily="@font/inter_medium"
                android:gravity="center" android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_loading_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_loading_sub"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    </FrameLayout>

    <!-- ===================================================================
         PLAYLIST SWITCHER MODAL — identik dengan portrait
         =================================================================== -->
    <LinearLayout
        android:id="@+id/switcher_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="#b3000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/switcher_modal"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_switcher_modal"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlist_switcher_title"
                android:textColor="#E4EEF0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="240dp">
                <LinearLayout
                    android:id="@+id/switcher_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <TextView
                android:id="@+id/btn_switcher_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlist_switcher_close"
                android:textColor="#8AACB0"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_btn_secondary"
                android:focusable="true"
                android:clickable="true"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
